  "flow": {
    "triggers": [
      {
        "id": "ebike_battery_below",
        "title": {
          "en": "eBike battery drops below"
        },
        "titleFormatted": {
          "en": "eBike battery drops below [[percentage]]%"
        },
        "hint": {
          "en": "Triggers when the battery level drops below a specified percentage."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ebike"
          },
          {
            "name": "percentage",
            "type": "number",
            "min": 1,
            "max": 99,
            "step": 1,
            "label": {
              "en": "%"
            }
          }
        ]
      },
      {
        "id": "ebike_charging_started",
        "title": {
          "en": "eBike charging started"
        },
        "hint": {
          "en": "Triggers when the eBike is plugged in and starts charging."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ebike"
          }
        ]
      },
      {
        "id": "ebike_charging_stopped",
        "title": {
          "en": "eBike charging stopped"
        },
        "hint": {
          "en": "Triggers when the eBike is unplugged or charging finishes."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ebike"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "ebike_battery_level_condition",
        "title": {
          "en": "eBike battery is !{{above|below}}"
        },
        "titleFormatted": {
          "en": "eBike battery is !{{above|below}} [[percentage]]%"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ebike"
          },
          {
            "name": "percentage",
            "type": "number",
            "min": 1,
            "max": 99,
            "step": 1,
            "label": {
              "en": "%"
            }
          }
        ]
      },
      {
        "id": "ebike_is_charging",
        "title": {
          "en": "eBike !{{is|is not}} charging"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=ebike"
          }
        ]
      }
    ]
  },
