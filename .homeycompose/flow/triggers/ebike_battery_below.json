{
  "id": "ebike_battery_below",
  "title": {
    "en": "eBike battery drops below"
  },
  "titleFormatted": {
    "en": "eBike battery drops below [[percentage]]%"
  },
  "hint": {
    "en": "Triggers when the battery level drops below a specified percentage."
  },
